-- ── Resolve the Stone Mask Handle via exact path ─────────────
local function getStoneMaskHandle()
    local serverJunk  = workspace:FindFirstChild("ServerJunk")
    local spawnedItems = serverJunk and serverJunk:FindFirstChild("SpawnedItems")
    local stoneMask   = spawnedItems and spawnedItems:FindFirstChild("Stone Mask")
    local handle      = stoneMask and stoneMask:FindFirstChild("Handle")
    if handle then return handle end
    -- Fallback: search anywhere in workspace for a Tool named "Stone Mask"
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") and obj.Name == "Stone Mask" then
            local h = obj:FindFirstChild("Handle")
            if h then return h end
        end
    end
    return nil
end

local autoMask     = false
local maskConn     = nil
local maskBusy     = false  -- prevents overlap, same pattern as ghostPunch

-- ── Ghost-teleport to the Handle, fire all pickup signals, return ─
local function ghostPickupMask(handle)
    if not HRP or not handle then return end
    if maskBusy then return end
    maskBusy = true

    task.spawn(function()
        local returnCF = HRP.CFrame

        -- Teleport onto the Handle so TouchTransmitter.TouchStarted fires
        HRP.CFrame = handle.CFrame

        -- Fire Tool signals on the parent Stone Mask tool
        local maskTool = handle.Parent
        if maskTool and maskTool:IsA("Tool") then
            pcall(function() maskTool:Activate() end)
            pcall(function()
                local rem = maskTool:FindFirstChildOfClass("RemoteEvent")
                if rem then rem:FireServer("Pickup", handle) end
            end)
        end

        -- Fire the workspace BindableEvents (Debris.Event & DeferredCallback.Event)
        local debrisEv   = workspace:FindFirstChild("Debris")
        local deferredEv = workspace:FindFirstChild("DeferredCallback")
        if debrisEv   and debrisEv:IsA("BindableEvent")   then pcall(function() debrisEv:Fire(handle)   end) end
        if deferredEv and deferredEv:IsA("BindableEvent") then pcall(function() deferredEv:Fire(handle) end) end

        -- Fire any ReplicatedStorage pickup remotes
        local rs = game:GetService("ReplicatedStorage")
        for _, name in ipairs({"Pickup", "PickupItem", "CollectItem", "ItemPickup", "TouchItem"}) do
            local rem = rs:FindFirstChild(name, true)
            if rem and rem:IsA("RemoteEvent") then
                pcall(function() rem:FireServer(handle) end)
            end
        end

        -- Dwell briefly so the server registers the touch, then snap back
        task.wait(DWELL_TIME)
        HRP.CFrame = returnCF
        maskBusy = false
    end)
end

local function startAutoMask()
    Toast("🎭 Auto Pick-up Stone Mask ON")
    -- Use a looping task rather than Heartbeat so task.wait() is safe
    task.spawn(function()
        while autoMask do
            local handle = getStoneMaskHandle()
            if handle then
                ghostPickupMask(handle)
            end
            task.wait(DWELL_TIME + 0.05)  -- wait just past the dwell so the previous ghost finishes
        end
    end)
end

local function stopAutoMask()
    autoMask = false
    maskBusy  = false
    Toast("🎭 Auto Pick-up Stone Mask OFF")
end

ToggleButton("🎭  Auto Pick-up Stone Mask", 18.9, function(on)
    autoMask = on
    if on then startAutoMask() else stopAutoMask() end
end)

