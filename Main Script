        "PATH:    " .. path,
        "PARENT:  " .. (target.Parent and target.Parent.Name or "nil"),
        "",
        "EVENTS ON CLICK:",
    }
    if #events == 0 then
        table.insert(copyLines, "  (none detected)")
    else
        for _, e in ipairs(events) do
            table.insert(copyLines, "  • " .. e)
        end
    end
    _lastFullText = table.concat(copyLines, "\n")

    -- Update card fields
    cardObjName.Text = target.Name
    classBadge.Text  = target.ClassName
    lineClass.Text   = "<font color=\"#FF7040\"><b>CLASS</b></font>  " .. target.ClassName
    linePath.Text    = "<font color=\"#FF7040\"><b>PATH</b></font>  " .. path
