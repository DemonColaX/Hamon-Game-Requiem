-- ── Shared helper: build a polished inline dropdown ──────────
-- Returns a rebuild function. The dropdown expands inline inside
-- the ScrollFrame (no z-fighting), pushing content below it down.
local function MakePlayerDropdown(labelText, layoutOrder, onSelect)
    -- Header button row
    local header = Instance.new("Frame")
