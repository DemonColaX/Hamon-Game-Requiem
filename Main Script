-- ── Ghost-teleport: hide → warp → dwell → return → show ──────
local punchBusy    = false
local DWELL_TIME   = 0.2

local function ghostPunch(tool, unionPart)
    if not HRP or not unionPart then return end
    if punchBusy then return end
    punchBusy = true

    task.spawn(function()
        setCharacterVisible(false)
        local returnCF = HRP.CFrame
        HRP.CFrame = unionPart.CFrame * CFrame.new(0, 0, -2)

        -- Fire all server-side signals while adjacent to the bag
        if tool then
            -- Primary: fire the tool's own server remote (most games use this)
            local remote = tool:FindFirstChildOfClass("RemoteEvent")
            if remote then pcall(function() remote:FireServer("Hit", unionPart) end) end
            -- Secondary: fire Activated signal for games that handle it client-side
            pcall(function() tool.Activated:Fire() end)
        end

        local bagModel = unionPart.Parent
        if bagModel then
            local cd = bagModel:FindFirstChildOfClass("ClickDetector")
            if cd then pcall(function() fireclickdetector(cd) end) end
            local pp = bagModel:FindFirstChildOfClass("ProximityPrompt", true)
            if pp then pcall(function() fireproximityprompt(pp) end) end
        end

        local rs = game:GetService("ReplicatedStorage")
        for _, name in ipairs({"Hit", "Punch", "PunchBag", "DamageBag", "BagHit"}) do
            local rem = rs:FindFirstChild(name, true)
            if rem and rem:IsA("RemoteEvent") then
                pcall(function() rem:FireServer(unionPart) end)
            end
        end

        task.wait(DWELL_TIME)
        HRP.CFrame = returnCF
        setCharacterVisible(true)
        punchBusy = false
    end)
end

-- ── Punch state ───────────────────────────────────────────────
local punchConnection = nil
local equippedTool    = nil
local punchCooldown   = 0
local PUNCH_INTERVAL  = 0.35
local vim             = game:GetService("VirtualInputManager")

local function startAutoPunch()
    -- Step 1: Find slot-1 tool. Hotbar order matches Backpack insertion order.
    local bp        = LocalPlayer:FindFirstChild("Backpack")
    local slot1Tool = nil

    if bp then
        for _, child in ipairs(bp:GetChildren()) do
            if child:IsA("Tool") then slot1Tool = child; break end
        end
    end

    -- Also accept a tool that is already equipped
    local alreadyHeld = Character and Character:FindFirstChildOfClass("Tool")
    if not slot1Tool then
        slot1Tool = alreadyHeld
    end

    if not slot1Tool then
        Toast("⚠ No tool in hotbar!")
        autoPunch = false
        punchToggleUI.SetState(false)
        return
    end

    -- Step 2: Equip slot-1 cleanly via the number-key press so the game's
    -- hotbar logic runs exactly as if the player pressed "1".
    -- We press key 1, wait for the character to actually hold the tool,
    -- then confirm equippedTool before starting the loop.
    if not alreadyHeld or alreadyHeld ~= slot1Tool then
        -- Unequip first so we start from a clean state
        pcall(function() Humanoid:UnequipTools() end)
        task.wait(0.05)

        -- Send the "1" key through VirtualInputManager (hotbar slot 1)
        pcall(function()
            vim:SendKeyEvent(true,  Enum.KeyCode.One, false, game)
            vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
        end)

        -- Wait up to 0.5 s for the tool to appear on the character
        local waited = 0
        while waited < 0.5 do
            task.wait(0.05)
            waited += 0.05
            local held = Character and Character:FindFirstChildOfClass("Tool")
            if held then break end
        end
    end

    equippedTool = Character and Character:FindFirstChildOfClass("Tool")
    if not equippedTool then
        -- Final fallback: force-equip via Humanoid API
        pcall(function() Humanoid:EquipTool(slot1Tool) end)
        task.wait(0.1)
        equippedTool = Character and Character:FindFirstChildOfClass("Tool") or slot1Tool
    end

    if not equippedTool then
        Toast("⚠ Could not equip slot 1 tool!")
        autoPunch = false
        punchToggleUI.SetState(false)
        return
    end

    Toast("🥊 Auto-Punch ON – " .. equippedTool.Name)
    punchCooldown = PUNCH_INTERVAL   -- fire first punch immediately

    -- Step 3: Heartbeat loop — on each interval, activate the tool directly
    -- (tool:Activate() is what Roblox calls internally on LMB) then also
    -- ghost-teleport to the bag and fire remotes for server-side registration.
    punchConnection = RunService.Heartbeat:Connect(function(dt)
        if not autoPunch then
            punchConnection:Disconnect()
            punchConnection = nil
            return
        end

        punchCooldown = punchCooldown - dt
        if punchCooldown > 0 then return end
        punchCooldown = PUNCH_INTERVAL

        -- Re-grab the tool each interval in case it changed
        equippedTool = Character and Character:FindFirstChildOfClass("Tool") or equippedTool

        -- Primary: call tool:Activate() — identical to what the engine does on LMB
        if equippedTool then
            pcall(function() equippedTool:Activate() end)
        end

        -- Secondary: send a real LMB click via VIM at the current mouse position
        -- so games that hook InputBegan rather than Tool.Activated also register it.
        -- task.spawn is required here — yielding inside a Heartbeat callback kills it.
        task.spawn(function()
            pcall(function()
                local mp = UserInputService:GetMouseLocation()
                vim:SendMouseButtonEvent(mp.X, mp.Y, 0, true,  game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(mp.X, mp.Y, 0, false, game, 1)
            end)
        end)

        -- Ghost-teleport to the bag and fire server remotes
        local unionPart = getPunchingBagUnion()
        if unionPart then
            ghostPunch(equippedTool, unionPart)
        end
    end)
end

local function stopAutoPunch()
    autoPunch = false
    if punchConnection then
        punchConnection:Disconnect()
        punchConnection = nil
    end
    setCharacterVisible(true)
    punchBusy = false
    Toast("🥊 Auto-Punch OFF")
end

