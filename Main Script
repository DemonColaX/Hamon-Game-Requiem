-- ── Event detection helper ────────────────────────────────────
local function getPath(obj)
    local parts, cur, limit = {}, obj, 8
    while cur and cur ~= game and limit > 0 do
        table.insert(parts, 1, cur.Name)
        cur = cur.Parent; limit -= 1
    end
    return table.concat(parts, " › ")
end

local function detectEvents(obj)
    local found, searchTargets = {}, {}
    local cur, depth = obj, 0
    while cur and cur ~= game and depth < 6 do
        table.insert(searchTargets, cur); cur = cur.Parent; depth += 1
    end
    for _, node in ipairs(searchTargets) do
        local prefix = (node == obj) and "" or ("[" .. node.Name .. "] ")
        local cd = node:FindFirstChildOfClass("ClickDetector")
        if cd then
            table.insert(found, prefix .. "ClickDetector.MouseClick")
            table.insert(found, prefix .. "ClickDetector.RightMouseClick")
            table.insert(found, prefix .. "ClickDetector.MouseHoverEnter / Leave")
        end
        local pp = node:FindFirstChildOfClass("ProximityPrompt")
        if pp then
            table.insert(found, prefix .. "ProximityPrompt.Triggered  [" .. pp.ActionText .. "]")
            table.insert(found, prefix .. "ProximityPrompt.PromptShown / Hidden")
        end
        if node:FindFirstChildOfClass("TouchTransmitter") then
            table.insert(found, prefix .. "TouchTransmitter.TouchStarted")
        end
        if node:IsA("Seat") or node:IsA("VehicleSeat") then
            table.insert(found, prefix .. node.ClassName .. ".Sit")
        end
        if node:IsA("Tool") then
            table.insert(found, prefix .. "Tool.Activated / Deactivated")
            table.insert(found, prefix .. "Tool.Equipped / Unequipped")
        end
        for _, child in ipairs(node:GetChildren()) do
            if child:IsA("Script") or child:IsA("LocalScript") or child:IsA("ModuleScript") then
                table.insert(found, prefix .. "Script: \"" .. child.Name .. "\" attached")
            end
            if child:IsA("RemoteEvent")    then table.insert(found, prefix .. "RemoteEvent: "    .. child.Name .. ".OnServerEvent")  end
            if child:IsA("RemoteFunction") then table.insert(found, prefix .. "RemoteFunction: " .. child.Name .. ".OnServerInvoke") end
            if child:IsA("BindableEvent")  then table.insert(found, prefix .. "BindableEvent: "  .. child.Name .. ".Event")          end
        end
        for _, store in ipairs({game:GetService("ReplicatedStorage"), game:GetService("ServerScriptService")}) do
            local remote = store:FindFirstChild(node.Name, true)
            if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
                table.insert(found, "ReplicatedStorage › " .. remote.Name .. " (" .. remote.ClassName .. ")")
            end
        end
    end
    local seen, unique = {}, {}
    for _, v in ipairs(found) do
        if not seen[v] then seen[v] = true; table.insert(unique, v) end
    end
    return unique
end

