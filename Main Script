            Rotation = isOpen and 180 or 0
        }):Play()

        -- Show "no players" hint
        if count == 0 and isOpen then
            local hint = Instance.new("TextLabel")
            hint.Size             = UDim2.new(1, 0, 0, 32)
            hint.BackgroundTransparency = 1
            hint.Text             = "No other players online"
            hint.TextColor3       = Color3.fromRGB(100, 100, 120)
            hint.TextSize         = 11
            hint.Font             = Enum.Font.Gotham
            hint.LayoutOrder      = 1
            hint.Parent           = listContainer
        end
    end

    headerBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        rebuild()
    end)

    Players.PlayerAdded:Connect(function() if isOpen then rebuild() end end)
    Players.PlayerRemoving:Connect(function(p)
        if selected == p then selected = nil; onSelect(nil, p) end
        if isOpen then rebuild() end
    end)

    return {
        getSelected  = function() return selected end,
        clearSelected = function() selected = nil; rebuild() end,
        setHeaderLabel = function(text)
            -- strip the old arrow suffix and replace label
            headerBtn.Text = text .. "  ▾"
        end,
    }
