local attachToggle
attachToggle = ToggleButton("🔗  Attach to Back (click player)", 10, function(on)
    if not on then
        if attachWeld then attachWeld:Destroy(); attachWeld = nil end
        Toast("Detached")
        return
    end
    Toast("Click a player to attach!")
    local conn
    conn = Mouse.Button1Down:Connect(function()
        conn:Disconnect()
        local target = Mouse.Target
        if not target then Toast("No target"); attachToggle.SetState(false); return end
        local targetChar = target:FindFirstAncestorOfClass("Model")
        if not targetChar then Toast("Not a character"); attachToggle.SetState(false); return end
        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHRP then Toast("No HRP"); attachToggle.SetState(false); return end
        if attachWeld then attachWeld:Destroy() end
        attachWeld = Instance.new("Weld")
        attachWeld.Part0 = targetHRP
        attachWeld.Part1 = HRP
        attachWeld.C0    = CFrame.new(0, 0, -2.5) -- behind back
        attachWeld.Parent = HRP
        Humanoid.PlatformStand = true
        Toast("Attached to " .. (targetChar.Name or "?"))
    end)
end)

