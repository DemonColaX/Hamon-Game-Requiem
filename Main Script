-- ── Resolve the Union part via exact path ────────────────────
local function getPunchingBagUnion()
    local root = workspace:FindFirstChild("Map")
    if root then
        local v   = root:FindFirstChild("Venice")
        local f   = v   and v:FindFirstChild("OLD FLOSS")
        local b   = f   and f:FindFirstChild("BUILDINGS")
        local b4  = b   and b:FindFirstChild("BUILDING4")
        local bld = b4  and b4:FindFirstChild("BUILDING")
        local bag = bld and bld:FindFirstChild("Punching Bag")
        local u   = bag and bag:FindFirstChild("Union")
        if u then return u end
    end
    -- Fallback: find any "Punching Bag" model with a Union child
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Punching Bag" and obj:IsA("Model") then
            local u = obj:FindFirstChild("Union")
            if u then return u end
        end
    end
    return nil
end

-- ── Visibility helpers ────────────────────────────────────────
local function setCharacterVisible(visible)
    if not Character then return end
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            part.LocalTransparencyModifier = visible and 0 or 1
        end
        if part:IsA("Decal") or part:IsA("Texture") then
