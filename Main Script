-- ── Ghost-punch a zombie HRP ──────────────────────────────────
-- Identical approach to ghostPunch(), but targets the zombie HRP
-- rather than a punching-bag Union.
local zombiePunchBusy = false

local function ghostPunchZombie(tool, zombieHRP)
    if not HRP or not zombieHRP then return end
    if zombiePunchBusy then return end
    zombiePunchBusy = true

    task.spawn(function()
        setCharacterVisible(false)
        local returnCF = HRP.CFrame
        -- Teleport 2 studs in front of the zombie so server range checks pass
        HRP.CFrame = zombieHRP.CFrame * CFrame.new(0, 0, -2)

        -- Fire all server-side signals while adjacent to the zombie
        if tool then
            local remote = tool:FindFirstChildOfClass("RemoteEvent")
            if remote then pcall(function() remote:FireServer("Hit", zombieHRP) end) end
            pcall(function() tool.Activated:Fire() end)
        end

        -- Fire ClickDetector / ProximityPrompt on the zombie model itself
        local zombieModel = zombieHRP.Parent
        if zombieModel then
            local cd = zombieModel:FindFirstChildOfClass("ClickDetector")
            if cd then pcall(function() fireclickdetector(cd) end) end
            local pp = zombieModel:FindFirstChildOfClass("ProximityPrompt", true)
            if pp then pcall(function() fireproximityprompt(pp) end) end
        end

        -- Fire any matching remotes in ReplicatedStorage
        local rs = game:GetService("ReplicatedStorage")
        for _, name in ipairs({"Hit", "Punch", "Damage", "DamageNPC", "ZombieHit", "NPCHit"}) do
            local rem = rs:FindFirstChild(name, true)
            if rem and rem:IsA("RemoteEvent") then
                pcall(function() rem:FireServer(zombieHRP) end)
            end
        end

        -- Fire the BindableEvents noted on the zombie's HRP
        -- (Debris.Event and DeferredCallback.Event)
        local debrisEvent   = workspace:FindFirstChild("Debris")
        local deferredEvent = workspace:FindFirstChild("DeferredCallback")
        if debrisEvent and debrisEvent:IsA("BindableEvent") then
            pcall(function() debrisEvent:Fire(zombieHRP) end)
        end
        if deferredEvent and deferredEvent:IsA("BindableEvent") then
            pcall(function() deferredEvent:Fire(zombieHRP) end)
        end

        task.wait(DWELL_TIME)
        HRP.CFrame = returnCF
        setCharacterVisible(true)
        zombiePunchBusy = false
    end)
end

-- ── Zombie punch state ────────────────────────────────────────
local autoPunchZombie     = false
local zombiePunchConn     = nil
local zombieEquippedTool  = nil
local hamonChargeConn     = nil   -- RenderStepped loop that holds G

local function startAutoPunchZombie()
    -- Find / equip slot-1 tool (same logic as Auto-Punch Bags)
    local bp        = LocalPlayer:FindFirstChild("Backpack")
    local slot1Tool = nil
    if bp then
        for _, child in ipairs(bp:GetChildren()) do
            if child:IsA("Tool") then slot1Tool = child; break end
        end
    end
    local alreadyHeld = Character and Character:FindFirstChildOfClass("Tool")
    if not slot1Tool then slot1Tool = alreadyHeld end

    if not slot1Tool then
        Toast("⚠ No tool in hotbar!")
        autoPunchZombie = false
        zombiePunchToggleUI.SetState(false)
        return
    end

    if not alreadyHeld or alreadyHeld ~= slot1Tool then
        pcall(function() Humanoid:UnequipTools() end)
        task.wait(0.05)
        pcall(function()
            vim:SendKeyEvent(true,  Enum.KeyCode.One, false, game)
            vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
        end)
        local waited = 0
        while waited < 0.5 do
            task.wait(0.05); waited += 0.05
            if Character and Character:FindFirstChildOfClass("Tool") then break end
        end
    end

    zombieEquippedTool = Character and Character:FindFirstChildOfClass("Tool")
    if not zombieEquippedTool then
        pcall(function() Humanoid:EquipTool(slot1Tool) end)
        task.wait(0.1)
        zombieEquippedTool = Character and Character:FindFirstChildOfClass("Tool") or slot1Tool
    end

    if not zombieEquippedTool then
        Toast("⚠ Could not equip slot 1 tool!")
        autoPunchZombie = false
        zombiePunchToggleUI.SetState(false)
        return
    end

    Toast("🧟 Auto-Punch Zombie ON – " .. zombieEquippedTool.Name .. " (G held)")
    -- Hold G to charge Hamon. Strategy: press G once, hold for a long window,
    -- release briefly, then press again. This mimics a real held keypress so
    -- games using IsKeyDown() / InputBegan / InputEnded all register it correctly.
    -- Spamming SendKeyEvent(true) every frame floods InputBegan with rapid
    -- press/release cycles instead of sustaining a genuine hold, which is why
    -- the bar wouldn't move before.
    if hamonChargeConn then hamonChargeConn:Disconnect() end

    local HAMON_HOLD = 1.5   -- seconds to hold G before cycling
    local HAMON_GAP  = 0.08  -- brief release so InputBegan fires again next cycle
    local hamonTimer = 0
    local hamonPhase = "hold"  -- starts in "hold" after the initial press below

    -- Initial press
    pcall(function() vim:SendKeyEvent(true, Enum.KeyCode.G, false, game) end)

    hamonChargeConn = RunService.Heartbeat:Connect(function(dt)
        if not autoPunchZombie then
            hamonChargeConn:Disconnect()
            hamonChargeConn = nil
            pcall(function() vim:SendKeyEvent(false, Enum.KeyCode.G, false, game) end)
            return
        end

        hamonTimer += dt

        if hamonPhase == "hold" and hamonTimer >= HAMON_HOLD then
            -- Release G briefly
            pcall(function() vim:SendKeyEvent(false, Enum.KeyCode.G, false, game) end)
            hamonPhase = "release"
            hamonTimer = 0

        elseif hamonPhase == "release" and hamonTimer >= HAMON_GAP then
            -- Press G again for the next hold window
            pcall(function() vim:SendKeyEvent(true, Enum.KeyCode.G, false, game) end)
            hamonPhase = "hold"
            hamonTimer = 0
        end
    end)

    -- Heartbeat loop — no interval cooldown; zombiePunchBusy (cleared after
    -- DWELL_TIME inside ghostPunchZombie) is the sole rate limiter, identical
    -- to how the bag punch works. This keeps the character invisible continuously.
    zombiePunchConn = RunService.Heartbeat:Connect(function(dt)
        if not autoPunchZombie then
            zombiePunchConn:Disconnect()
            zombiePunchConn = nil
            return
        end

        -- Skip if a ghost-punch is already in flight
        if zombiePunchBusy then return end

        zombieEquippedTool = Character and Character:FindFirstChildOfClass("Tool") or zombieEquippedTool

        -- Primary: tool:Activate()
        if zombieEquippedTool then
            pcall(function() zombieEquippedTool:Activate() end)
        end

        -- Secondary: real LMB click via VIM
        task.spawn(function()
            pcall(function()
                local mp = UserInputService:GetMouseLocation()
                vim:SendMouseButtonEvent(mp.X, mp.Y, 0, true,  game, 1)
                task.wait(0.05)
