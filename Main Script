SectionLabel("— ABILITIES", 7)

ActionButton("🌊  Interact: Zeppeli (Hamon)", 8, function()
    -- Exact path: Workspace > NPCs > Zeppeli > HumanoidRootPart
    local npcs    = workspace:FindFirstChild("NPCs")
    local zeppeli = npcs and npcs:FindFirstChild("Zeppeli")
    local hrp     = zeppeli and zeppeli:FindFirstChild("HumanoidRootPart")

    if not hrp then
        -- Fallback: deep search in case hierarchy differs
        hrp = workspace:FindFirstChild("HumanoidRootPart", true)
        zeppeli = hrp and hrp.Parent
    end

    if not zeppeli then
        Toast("❌ Zeppeli not found in Workspace > NPCs")
        return
    end

    -- Store where we came from so we can teleport back
    local returnCF = HRP and HRP.CFrame

    -- 1. Teleport close to Zeppeli so proximity/range checks pass server-side
    if hrp and HRP then
        HRP.CFrame = hrp.CFrame * CFrame.new(0, 0, -4)
    end

    local interacted = false

    -- 2. Fire ClickDetector on Zeppeli (the primary event per inspector data)
    local cd = zeppeli:FindFirstChildOfClass("ClickDetector")
    if cd then
        fireclickdetector(cd)
        Toast("✅ Interacted with Zeppeli!")
        interacted = true
    end

    -- 3. Also check HumanoidRootPart itself for a ClickDetector
    if hrp then
        local hrpCd = hrp:FindFirstChildOfClass("ClickDetector")
        if hrpCd then
            fireclickdetector(hrpCd)
            if not interacted then Toast("✅ Fired ClickDetector on HRP!") end
            interacted = true
        end
    end

    -- 4. Fire any ProximityPrompt as a secondary attempt
    local pp = zeppeli:FindFirstChildOfClass("ProximityPrompt", true)
    if pp then
        fireproximityprompt(pp)
        if not interacted then Toast("✅ Fired ProximityPrompt on Zeppeli!") end
        interacted = true
    end

    -- 5. Trigger the "Zeppeli" Script's logic via a BindableEvent if present
    local be = zeppeli:FindFirstChild("Zeppeli")
    if be and be:IsA("BindableEvent") then
        be:Fire()
        interacted = true
    end

    if not interacted then
        Toast("⚠ Found Zeppeli but no interactable events detected")
    end

    -- 6. Immediately teleport back to original position
    if HRP and returnCF then
        HRP.CFrame = returnCF
    end
end)

-- ── Wipe Character (double-press within 2 s) ─────────────────
do
    local wipeLastPress = 0

    ActionButton("💀  Wipe Character  (press twice)", 8.5, function()
        local now = tick()

        if (now - wipeLastPress) > 2 then
            -- First press — arm it
            wipeLastPress = now
            Toast("💀 Press again within 2s to confirm!")
            return
        end

        -- Second press within 2 s — execute
        wipeLastPress = 0

        local altar = workspace:FindFirstChild("AltarOfSacrifice")
        if not altar then
            Toast("❌ AltarOfSacrifice not found in Workspace")
            return
        end

        local cd = altar:FindFirstChildOfClass("ClickDetector")
        if not cd then
            Toast("❌ No ClickDetector on AltarOfSacrifice")
            return
        end

        local returnCF = HRP and HRP.CFrame

        -- Fire twice: teleport adjacent so server range checks pass,
        -- fire the ClickDetector, then snap back — identical pattern
        -- to the Zeppeli interaction.
        local function fireOnce()
            if HRP then
                HRP.CFrame = altar.CFrame * CFrame.new(0, 0, -3)
            end
            pcall(function() fireclickdetector(cd) end)
            if HRP and returnCF then
                HRP.CFrame = returnCF
            end
        end

        fireOnce()
        fireOnce()

        Toast("💀 Wipe Character fired!")
    end)
end

