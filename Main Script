                    rebuild()
                end)
            end
        end

        -- Animate height
        local rowH   = 34
        local padH   = 8
        local target = isOpen and (count > 0 and count * rowH + padH or 32) or 0
        TweenService:Create(listContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quart), {
